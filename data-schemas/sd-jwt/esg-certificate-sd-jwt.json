{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webuildconsortium.eu/schemas/esg-certificate-sd-jwt.json",
  "title": "WeBuild – ESG Certificate Attestation – SD-JWT VC payload",
  "description": "Schema for the SD-JWT VC payload of an ESG Certificate Attestation as defined in the ESG Certificate Attestation Rulebook (Chapter 3.2). This models the JSON claims set prior to SD-JWT disclosure/packing. The attestation provides a standardized, verifiable digital representation of Environmental, Social, and Governance certificates held by a legal entity, enabling structured exchange of certification data for KYS, supplier onboarding, compliance verification, and regulatory audit processes.",
  "type": "object",
  "version": "0.3.0",
  "additionalProperties": true,
  "properties": {
    "vct": {
      "type": "string",
      "const": "eu.we-build:esgcertificate:1"
    },
    "iss": {
      "type": "string",
      "format": "uri"
    },
    "iat": {
      "type": "integer"
    },
    "exp": {
      "type": "integer"
    },
    "jti": {
      "type": "string"
    },
    "attestation_legal_category": {
      "type": "string",
      "enum": [
        "EAA",
        "QEAA"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "trust_anchor_url": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "string",
      "description": "Type of the certificate (e.g., ISO 9001)."
    },
    "version": {
      "type": "string",
      "description": "Version of the certificate standard (e.g., '2015')."
    },
    "registration_number": {
      "type": "string",
      "description": "Registration number from the certificate."
    },
    "registration_initial_date": {
      "type": "string",
      "format": "date",
      "description": "Valid-from date of the certificate (YYYY-MM-DD)."
    },
    "registration_expiration_date": {
      "type": "string",
      "format": "date",
      "description": "Valid-until date of the certificate (YYYY-MM-DD)."
    },
    "legal_entity": {
      "type": "object",
      "properties": {
        "legal_person": {
          "type": "object",
          "properties": {
            "legal_person_name": {
              "type": "string"
            },
            "legal_form_type": {
              "type": "string"
            }
          },
          "required": [
            "legal_person_name",
            "legal_form_type"
          ]
        },
        "identifier": {
          "type": "object",
          "description": "At least one identifier is required.",
          "properties": {
            "euid": {
              "type": "string"
            },
            "lei": {
              "type": "string"
            },
            "tax": {
              "type": "string"
            },
            "gln": {
              "type": "string"
            },
            "duns": {
              "type": "string"
            },
            "eori": {
              "type": "string"
            },
            "bpnl": {
              "type": "string"
            },
            "siren": {
              "type": "string"
            }
          }
        },
        "address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "house_number": {
              "type": "string"
            },
            "locality": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "postal_code": {
              "type": "string"
            },
            "country": {
              "type": "string"
            }
          },
          "required": [
            "street",
            "house_number",
            "locality",
            "postal_code",
            "country"
          ]
        }
      },
      "required": [
        "legal_person",
        "identifier",
        "address"
      ]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "legal_entity_name": {
            "type": "string"
          },
          "legal_entity_identifier": {
            "type": "object",
            "description": "At least one identifier required.",
            "properties": {
              "euid": {
                "type": "string"
              },
              "lei": {
                "type": "string"
              },
              "tax": {
                "type": "string"
              },
              "gln": {
                "type": "string"
              },
              "duns": {
                "type": "string"
              },
              "eori": {
                "type": "string"
              },
              "bpnl": {
                "type": "string"
              },
              "siren": {
                "type": "string"
              }
            }
          },
          "site_identifier": {
            "type": "string",
            "format": "uuid"
          },
          "site_address": {
            "type": "object",
            "properties": {
              "street": {
                "type": "string"
              },
              "house_number": {
                "type": "string"
              },
              "locality": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "postal_code": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            },
            "required": [
              "street",
              "house_number",
              "locality",
              "postal_code",
              "country"
            ]
          },
          "scope_description": {
            "type": "string"
          },
          "certified_site": {
            "type": "boolean"
          }
        },
        "required": [
          "legal_entity_name",
          "legal_entity_identifier",
          "site_address",
          "scope_description",
          "certified_site"
        ]
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "data": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "required": [
        "id",
        "type"
      ]
    },
    "status": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "status_list_credential": {
          "type": "string",
          "format": "uri"
        },
        "status_list_index": {
          "type": "integer"
        },
        "status_purpose": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "status_list_credential",
        "status_list_index",
        "status_purpose"
      ]
    },
    "cnf": {
      "type": "object",
      "properties": {
        "jwk": {
          "type": "object"
        }
      },
      "required": [
        "jwk"
      ]
    }
  },
  "required": [
    "vct",
    "iss",
    "iat",
    "exp",
    "attestation_legal_category",
    "type",
    "version",
    "registration_number",
    "registration_initial_date",
    "registration_expiration_date",
    "legal_entity",
    "scope",
    "evidence",
    "cnf"
  ]
}