{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webuildconsortium.eu/schemas/payment-terms-sd-jwt.json",
  "title": "WeBuild Payment Terms Attestation SD-JWT VC payload",
  "description": "Schema for the SD-JWT VC payload of a Payment Terms Attestation as defined in the Payment Terms Attestation Rulebook (Chapter 3.2).",
  "type": "object",
  "version": "0.1.0",
  "additionalProperties": true,
  "properties": {
    "vct": {
      "type": "string",
      "const": "eu.we-build:paymentterms:1"
    },
    "iss": {
      "type": "string",
      "format": "uri"
    },
    "iat": {
      "type": "integer"
    },
    "exp": {
      "type": "integer"
    },
    "issuing_entity": {
      "type": "string"
    },
    "issuing_country": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "attestation_legal_category": {
      "type": "string",
      "const": "EAA"
    },
    "schema_version": {
      "type": "string"
    },
    "trust_anchor_url": {
      "type": "string",
      "format": "uri"
    },
    "payment_due": {
      "type": "string",
      "pattern": "^P([0-9]+D)?(T([0-9]+H)?([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?)?$"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "incoterm": {
      "type": "string",
      "enum": [
        "EXW",
        "FCA",
        "CPT",
        "CIP",
        "DAP",
        "DPU",
        "DDP",
        "FAS",
        "FOB",
        "CFR",
        "CIF"
      ]
    },
    "buyer_identifier": {
      "type": "object",
      "description": "Unique identifiers of the buyer party. At least one identifier MUST be present.",
      "properties": {
        "euid": {
          "type": "string"
        },
        "lei": {
          "type": "string"
        },
        "tax": {
          "type": "string"
        },
        "gln": {
          "type": "string"
        },
        "duns": {
          "type": "string"
        },
        "eori": {
          "type": "string"
        },
        "bpnl": {
          "type": "string"
        },
        "siren": {
          "type": "string"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "supplier_identifier": {
      "type": "object",
      "description": "Unique identifiers of the supplier party. At least one identifier MUST be present.",
      "properties": {
        "euid": {
          "type": "string"
        },
        "lei": {
          "type": "string"
        },
        "tax": {
          "type": "string"
        },
        "gln": {
          "type": "string"
        },
        "duns": {
          "type": "string"
        },
        "eori": {
          "type": "string"
        },
        "bpnl": {
          "type": "string"
        },
        "siren": {
          "type": "string"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "agreement_date": {
      "type": "string",
      "format": "date"
    },
    "payment_reference_event": {
      "type": "string",
      "enum": [
        "invoice_date",
        "delivery_date",
        "order_date",
        "acceptance_date",
        "shipment_date"
      ]
    },
    "contract_reference": {
      "type": "string"
    },
    "transaction_amount": {
      "type": "number",
      "minimum": 0
    },
    "delivery_location": {
      "type": "string"
    },
    "status": {
      "type": "object",
      "required": [
        "type",
        "status_list_credential",
        "status_list_index",
        "status_purpose"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "status-list"
        },
        "status_list_credential": {
          "type": "string",
          "format": "uri"
        },
        "status_list_index": {
          "type": "integer",
          "minimum": 0
        },
        "status_purpose": {
          "type": "string",
          "const": "revocation"
        }
      }
    },
    "cnf": {
      "type": "object",
      "properties": {
        "jwk": {
          "type": "object"
        }
      },
      "required": [
        "jwk"
      ]
    }
  },
  "required": [
    "vct",
    "iss",
    "iat",
    "exp",
    "attestation_legal_category",
    "payment_due",
    "currency",
    "incoterm",
    "buyer_identifier",
    "supplier_identifier",
    "agreement_date",
    "cnf"
  ]
}