{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webuildconsortium.eu/schemas/ubo-attestation/0.4.0/ubo-attestation-schema.json",
  "title": "Ultimate Beneficial Owner (UBO) Attestation",
  "description": "SD-JWT VC schema for the WeBuild UBO Attestation (vct: eu.we-build:ubo:1). Provides a standardized, verifiable representation of the natural persons who ultimately own or control a legal entity, compliant with AMLR 2024/1624.",
  "type": "object",
  "required": [
    "vct",
    "iss",
    "iat",
    "exp",
    "attestation_legal_category",
    "ubo"
  ],
  "properties": {
    "vct": {
      "type": "string",
      "const": "eu.we-build:ubo:1"
    },
    "iss": {
      "type": "string",
      "minLength": 1
    },
    "iat": {
      "type": "integer",
      "minimum": 0
    },
    "exp": {
      "type": "integer",
      "minimum": 0
    },
    "jti": {
      "type": "string",
      "minLength": 1
    },
    "attestation_legal_category": {
      "type": "string",
      "enum": [
        "EAA",
        "QEAA"
      ]
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trust_anchor_url": {
      "type": "string",
      "format": "uri"
    },
    "ubo": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/UBOEntry"
      }
    },
    "status": {
      "type": "object",
      "required": [
        "type",
        "status_list_credential",
        "status_list_index",
        "status_purpose"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "status-list"
        },
        "status_list_credential": {
          "type": "string",
          "format": "uri"
        },
        "status_list_index": {
          "type": "integer",
          "minimum": 0
        },
        "status_purpose": {
          "type": "string",
          "const": "revocation"
        }
      }
    },
    "cnf": {
      "type": "object",
      "properties": {
        "jwk": {
          "type": "object"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "UBOEntry": {
      "type": "object",
      "title": "UBOEntry",
      "required": [
        "jurisdiction",
        "person",
        "birth_place",
        "citizenship",
        "residential_address",
        "person_identifier",
        "justification",
        "effective_date",
        "source"
      ],
      "properties": {
        "jurisdiction": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "person": {
          "$ref": "#/$defs/Person"
        },
        "birth_place": {
          "$ref": "#/$defs/BirthPlace"
        },
        "citizenship": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          }
        },
        "residential_address": {
          "$ref": "#/$defs/Address"
        },
        "contact_address": {
          "$ref": "#/$defs/Address"
        },
        "person_identifier": {
          "$ref": "#/$defs/PersonIdentifier"
        },
        "person_unique_identifier": {
          "$ref": "#/$defs/PersonUniqueIdentifier"
        },
        "justification": {
          "$ref": "#/$defs/Justification"
        },
        "effective_date": {
          "type": "string",
          "format": "date"
        },
        "source": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Source"
          }
        }
      }
    },
    "Person": {
      "type": "object",
      "title": "Person",
      "required": [
        "first_name",
        "surname",
        "birth_date"
      ],
      "properties": {
        "first_name": {
          "type": "string",
          "minLength": 1
        },
        "surname": {
          "type": "string",
          "minLength": 1
        },
        "birth_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "BirthPlace": {
      "type": "object",
      "title": "BirthPlace",
      "required": [
        "locality",
        "country"
      ],
      "properties": {
        "locality": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "region": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Address": {
      "type": "object",
      "title": "Address",
      "required": [
        "street",
        "house_number",
        "locality",
        "region",
        "postal_code",
        "country"
      ],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1
        },
        "house_number": {
          "type": "string",
          "minLength": 1
        },
        "locality": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "postal_code": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        }
      }
    },
    "PersonIdentifier": {
      "type": "object",
      "title": "PersonIdentifier",
      "required": [
        "document_type",
        "document_number",
        "issuing_country",
        "expiry_date"
      ],
      "properties": {
        "document_type": {
          "type": "string",
          "enum": [
            "PASSPORT",
            "NATIONAL_ID",
            "RESIDENCE_PERMIT",
            "DRIVING_LICENSE",
            "OTHER"
          ]
        },
        "document_number": {
          "type": "string",
          "minLength": 1
        },
        "issuing_country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "expiry_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "PersonUniqueIdentifier": {
      "type": "object",
      "title": "PersonUniqueIdentifier",
      "properties": {
        "identifier_unique": {
          "type": "string",
          "minLength": 1
        },
        "identifier_issuing_authority": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Justification": {
      "type": "object",
      "title": "Justification",
      "required": [
        "threshold_met"
      ],
      "properties": {
        "threshold_met": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "ownership_25_plus",
              "ownership_direct",
              "ownership_indirect",
              "control_voting_25_plus",
              "control_voting_direct",
              "control_voting_indirect",
              "control_management",
              "control_veto",
              "control_contractual",
              "control_family_relationships",
              "control_acting_in_concert",
              "control_nominee",
              "control_other_means",
              "arrangement_settlor",
              "arrangement_trustee",
              "arrangement_beneficiary",
              "arrangement_protector",
              "arrangement_object_of_power",
              "arrangement_default_taker",
              "arrangement_other_control"
            ]
          }
        },
        "ownership_percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "voting_rights_percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "control_details": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Source": {
      "type": "object",
      "title": "Source",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "ShareRegister",
            "CommercialRegister",
            "TransparencyRegister",
            "TrustDeed",
            "ShareholderAgreement",
            "ArticlesOfAssociation",
            "GovernanceChart",
            "AMLOfficerDeclaration",
            "NotarialDeed",
            "Other"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "data": {
          "type": "string",
          "contentEncoding": "base64"
        }
      }
    }
  }
}