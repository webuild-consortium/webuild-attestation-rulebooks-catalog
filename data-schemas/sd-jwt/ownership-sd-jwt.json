{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://we-build.example.com/schemas/ownership/1.0/sd-jwt-vc-schema.json",
  "title": "Ownership Attestation SD-JWT VC Schema",
  "description": "Schema for the Ownership Attestation encoded as SD-JWT VC, based on the WeBuild Attestation Rulebook v0.9 and draft-ietf-oauth-sd-jwt-vc-09. Records all natural persons, legal entities, and legal arrangements holding direct or indirect ownership interests in a legal entity.",
  "type": "object",
  "required": [
    "vct",
    "iss",
    "iat",
    "exp",
    "attestation_legal_category",
    "issuing_entity",
    "owner"
  ],
  "properties": {
    "vct": {
      "type": "string",
      "const": "eu.we-build:ownership:1"
    },
    "iss": {
      "type": "string",
      "format": "uri"
    },
    "iat": {
      "type": "integer",
      "minimum": 0
    },
    "exp": {
      "type": "integer",
      "minimum": 0
    },
    "nbf": {
      "type": "integer",
      "minimum": 0
    },
    "sub": {
      "type": "string"
    },
    "issuing_entity": {
      "type": "string"
    },
    "attestation_legal_category": {
      "type": "string",
      "enum": [
        "EAA",
        "QEAA"
      ]
    },
    "schema_version": {
      "type": "string",
      "example": "0.9.0"
    },
    "trust_anchor_url": {
      "type": "string",
      "format": "uri"
    },
    "cnf": {
      "type": "object",
      "properties": {
        "jwk": {
          "type": "object",
          "required": [
            "kty"
          ],
          "properties": {
            "kty": {
              "type": "string"
            },
            "crv": {
              "type": "string"
            },
            "x": {
              "type": "string"
            },
            "y": {
              "type": "string"
            }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "required": [
        "type",
        "status_list_credential",
        "status_list_index",
        "status_purpose"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "status-list"
        },
        "status_list_credential": {
          "type": "string",
          "format": "uri"
        },
        "status_list_index": {
          "type": "integer",
          "minimum": 0
        },
        "status_purpose": {
          "type": "string",
          "const": "revocation"
        }
      },
      "additionalProperties": false
    },
    "owner": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Owner"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Owner": {
      "type": "object",
      "title": "Owner",
      "required": [
        "type",
        "jurisdiction",
        "address",
        "interests",
        "effective_date",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Person",
            "Entity"
          ]
        },
        "jurisdiction": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "person": {
          "$ref": "#/$defs/Person"
        },
        "entity": {
          "$ref": "#/$defs/Entity"
        },
        "address": {
          "$ref": "#/$defs/Address"
        },
        "interests": {
          "$ref": "#/$defs/Interests"
        },
        "effective_date": {
          "type": "string",
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Evidence"
          }
        }
      },
      "if": {
        "properties": {
          "type": {
            "const": "Person"
          }
        }
      },
      "then": {
        "required": [
          "person"
        ]
      },
      "else": {
        "required": [
          "entity"
        ]
      },
      "additionalProperties": false
    },
    "Person": {
      "type": "object",
      "title": "Person",
      "required": [
        "first_name",
        "surname",
        "birth_date"
      ],
      "properties": {
        "first_name": {
          "type": "string",
          "minLength": 1
        },
        "surname": {
          "type": "string",
          "minLength": 1
        },
        "birth_date": {
          "type": "string",
          "format": "date",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "additionalProperties": false
    },
    "Entity": {
      "type": "object",
      "title": "Entity",
      "required": [
        "category",
        "name",
        "identifier",
        "jurisdiction",
        "form"
      ],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "legal_entity",
            "legal_arrangement"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "identifier": {
          "$ref": "#/$defs/EntityIdentifier"
        },
        "jurisdiction": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "legal_form": {
          "type": "string"
        },
        "form": {
          "type": "string",
          "enum": [
            "private_company",
            "public_company",
            "partnership",
            "limited_partnership",
            "trust",
            "foundation",
            "cooperative",
            "state_owned_enterprise",
            "other"
          ]
        },
        "subtype_info": {
          "$ref": "#/$defs/SubtypeInfo"
        }
      },
      "if": {
        "anyOf": [
          {
            "properties": {
              "category": {
                "const": "legal_arrangement"
              }
            }
          },
          {
            "properties": {
              "form": {
                "const": "trust"
              }
            }
          }
        ]
      },
      "then": {
        "required": [
          "subtype_info"
        ]
      },
      "additionalProperties": false
    },
    "EntityIdentifier": {
      "type": "object",
      "title": "EntityIdentifier",
      "properties": {
        "euid": {
          "type": "string",
          "minLength": 1
        },
        "lei": {
          "type": "string",
          "minLength": 20,
          "maxLength": 20
        },
        "tax": {
          "type": "string",
          "minLength": 1
        },
        "other": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "euid"
          ]
        },
        {
          "required": [
            "lei"
          ]
        },
        {
          "required": [
            "tax"
          ]
        },
        {
          "required": [
            "other"
          ]
        }
      ],
      "additionalProperties": false
    },
    "SubtypeInfo": {
      "type": "object",
      "title": "SubtypeInfo",
      "required": [
        "settlement",
        "purpose",
        "assets"
      ],
      "properties": {
        "settlement": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "assets": {
          "type": "string",
          "minLength": 1
        },
        "reason_for_registration": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Address": {
      "type": "object",
      "title": "Address",
      "required": [
        "street",
        "house_number",
        "locality",
        "region",
        "postal_code",
        "country"
      ],
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1
        },
        "house_number": {
          "type": "string",
          "minLength": 1
        },
        "locality": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "postal_code": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        }
      },
      "additionalProperties": false
    },
    "Interests": {
      "type": "object",
      "title": "Interests",
      "required": [
        "type",
        "level",
        "percentage",
        "quantity",
        "rights"
      ],
      "properties": {
        "type": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "shareholding",
              "nomineeShareholding",
              "votingRights",
              "appointmentOfBoard",
              "otherInfluenceOrControl",
              "seniorManagingOfficial",
              "settlor",
              "trustee",
              "protector",
              "beneficiaryOfLegalArrangement",
              "rightsGrantedByContract",
              "conditionalRightsGrantedByContract",
              "economicBeneficiary",
              "controlViaCompanyRulesOrArticles",
              "controlByLegalFramework"
            ]
          }
        },
        "level": {
          "type": "string",
          "enum": [
            "direct",
            "indirect",
            "joint",
            "unknown"
          ]
        },
        "percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "quantity": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        },
        "class": {
          "type": "string",
          "enum": [
            "ordinary",
            "preferred",
            "dual-class",
            "other"
          ]
        },
        "rights": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "dividend_rights",
              "liquidation_rights"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "Evidence": {
      "type": "object",
      "title": "Evidence",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "officialRegister",
            "selfDeclaration",
            "thirdPartyVerification",
            "trustDeed",
            "shareholderAgreement",
            "articlesOfAssociation",
            "governanceChart"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "data": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "additionalProperties": false
    }
  }
}